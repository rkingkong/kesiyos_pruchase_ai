<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_purchase_ai_wizard" model="ir.actions.act_window">
        <field name="name">📄 Escanear Factura con IA</field>
        <field name="res_model">purchase.ai.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

    <record id="view_purchase_ai_wizard_form" model="ir.ui.view">
        <field name="name">purchase.ai.wizard.form</field>
        <field name="model">purchase.ai.wizard</field>
        <field name="arch" type="xml">
            <form string="Escanear Factura → Orden de Compra">

                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="upload,review,approve,done"/>
                </header>

                <sheet>

                    <!-- ══════════════════════════════════════════════
                         STAGE 1 — UPLOAD
                         ══════════════════════════════════════════════ -->
                    <group invisible="state != 'upload'">

                        <group string="📄 Subir Documento">
                            <field name="document_file"
                                   widget="binary"
                                   string="Factura / Recibo"
                                   filename="document_filename"
                                   required="state == 'upload'"/>
                            <field name="document_filename" invisible="1"/>
                            <field name="document_mimetype" invisible="1"/>
                        </group>

                        <!-- Viáticos toggle -->
                        <group string="⚙️ Opciones de Procesamiento">
                            <field name="is_viaticos" string="💼 Agrupar todo como Viáticos / Gasto General"/>
                            <div invisible="not is_viaticos"
                                 style="padding:10px;background:#d1ecf1;border-left:4px solid #17a2b8;border-radius:4px;margin-top:4px;">
                                <b>Modo Viáticos activado.</b><br/>
                                No se hará matching de productos. Todas las líneas de la
                                factura se agruparán en <b>una sola línea</b> usando el
                                producto <b>Viáticos</b>, con la descripción completa
                                de cada ítem como detalle.
                                <br/>Ideal para: gastos del dueño, viáticos, representación,
                                servicios varios.
                            </div>
                            <div invisible="is_viaticos"
                                 style="padding:10px;background:#f0f4ff;border-left:4px solid #6c8ebf;border-radius:4px;margin-top:4px;">
                                <b>Modo normal.</b><br/>
                                La IA extraerá cada línea y buscará coincidencias en tu
                                catálogo de productos. Podrás revisar y corregir antes de
                                crear la Orden de Compra.
                            </div>
                        </group>

                    </group>

                    <!-- ══════════════════════════════════════════════
                         STAGE 2 — REVIEW
                         ══════════════════════════════════════════════ -->
                    <group invisible="state not in ('review', 'approve')">

                        <div invisible="not matching_summary" colspan="4">
                            <field name="matching_summary" widget="html" nolabel="1"/>
                        </div>

                        <!-- Vendor block -->
                        <group string="🏪 Proveedor" colspan="4">
                            <group>
                                <field name="vendor_nit" string="NIT"/>
                                <field name="vendor_name_raw" string="Nombre (factura)"/>
                                <field name="vendor_state" widget="badge"
                                       decoration-success="vendor_state in ('found', 'created', 'manual')"
                                       decoration-warning="vendor_state == 'name_match'"
                                       decoration-danger="vendor_state == 'not_found'"/>
                            </group>
                            <group>
                                <field name="vendor_id"
                                       string="Proveedor en Odoo"
                                       options="{'no_quick_create': false}"
                                       domain="[('supplier_rank', '&gt;', 0)]"/>
                                <field name="vendor_address" optional="show"/>
                            </group>
                            <div colspan="4" style="margin-top:4px">
                                <button name="action_lookup_vendor_by_nit"
                                        type="object"
                                        string="🔍 Buscar por NIT"
                                        class="btn-secondary btn-sm"/>
                                <button name="action_create_vendor"
                                        type="object"
                                        string="➕ Crear Proveedor"
                                        class="btn-warning btn-sm"
                                        invisible="vendor_id != False"/>
                            </div>
                        </group>

                        <!-- Invoice header -->
                        <group string="📋 Factura">
                            <field name="invoice_number"/>
                            <field name="invoice_date"
                                   required="state in ('review', 'approve')"/>
                            <field name="fel_uuid" string="UUID FEL / SAT" optional="show"/>
                            <field name="fel_serie" string="Serie DTE" optional="show"/>
                            <field name="currency_id" options="{'no_open': True}"/>
                        </group>
                        <group string="💰 Totales">
                            <field name="subtotal_before_tax" string="Subtotal s/IVA"/>
                            <field name="tax_amount" string="IVA"/>
                            <field name="total_amount" string="Total"/>
                        </group>

                        <!-- Lines -->
                        <notebook colspan="4">
                            <page string="📦 Líneas de Factura">
                                <field name="line_ids" nolabel="1">
                                    <tree editable="bottom"
                                          decoration-success="match_confidence == 'high'"
                                          decoration-warning="match_confidence == 'medium'"
                                          decoration-danger="match_confidence in ('low', 'none')"
                                          decoration-info="match_confidence in ('manual', 'created')">
                                        <field name="description" string="Descripción"/>
                                        <field name="product_id"
                                               string="Producto Odoo"
                                               domain="[('purchase_ok','=',True)]"
                                               options="{'no_quick_create': false}"
                                               widget="many2one"/>
                                        <field name="match_confidence" string="Confianza" optional="show"/>
                                        <field name="match_score"      string="%" optional="show"/>
                                        <field name="match_reason"     string="Razón" optional="show"/>
                                        <field name="suggested_product_name" string="Nombre sugerido" optional="show"/>
                                        <button name="action_create_product"
                                                type="object"
                                                string="🆕"
                                                title="Asignar producto"
                                                invisible="product_id != False"
                                                class="btn-sm btn-outline-primary"/>
                                        <field name="product_code" string="Cód. Proveedor" optional="hide"/>
                                        <field name="quantity" string="Cant."/>
                                        <field name="uom_id"   string="UOM" optional="show"/>
                                        <field name="unit_price" string="P. Unit."/>
                                        <field name="line_total" string="Subtotal" optional="show"/>
                                        <field name="tax_ids"
                                               widget="many2many_tags"
                                               optional="show"
                                               domain="[('type_tax_use','=','purchase')]"/>
                                        <field name="needs_product" invisible="1"/>
                                    </tree>
                                </field>
                                <div invisible="unmatched_count == 0"
                                     style="margin-top:6px;color:#dc3545;font-size:0.9em">
                                    ⚠️ <field name="unmatched_count" nolabel="1"
                                              style="display:inline;font-weight:bold"/> línea(s) sin producto.
                                    Asígnales un producto manualmente o usa el botón 🆕.
                                </div>
                            </page>

                            <page string="🤖 Debug IA">
                                <group string="Fase 1 — Extracción (JSON crudo)">
                                    <field name="ai_raw_json" widget="text" readonly="1" nolabel="1"/>
                                </group>
                                <group string="Fase 2 — Matching (JSON crudo)">
                                    <field name="ai_matching_json" widget="text" readonly="1" nolabel="1"/>
                                </group>
                                <div invisible="not ai_error_message" style="color:red;padding:8px">
                                    <b>Error:</b> <field name="ai_error_message" readonly="1" nolabel="1"/>
                                </div>
                            </page>
                        </notebook>

                    </group>

                    <!-- ══════════════════════════════════════════════
                         STAGE 3 — APPROVE
                         ══════════════════════════════════════════════ -->
                    <group invisible="state != 'approve'">

                        <div class="kes-info" colspan="4" style="margin-bottom:12px">
                            <b>Revisa los puntos a continuación y marca cada casilla.</b><br/>
                            La Orden de Compra se creará en estado <b>Borrador</b>.
                        </div>

                        <!-- Viáticos reminder in approve stage -->
                        <div invisible="not is_viaticos" colspan="4"
                             style="padding:10px;background:#d1ecf1;border-left:4px solid #17a2b8;border-radius:4px;margin-bottom:8px;">
                            💼 <b>Modo Viáticos</b> — Esta orden se registrará como gasto general.
                        </div>

                        <group string="📋 Resumen" colspan="4">
                            <group>
                                <field name="vendor_id"      readonly="1" string="Proveedor"/>
                                <field name="vendor_nit"     readonly="1"/>
                                <field name="invoice_number" readonly="1"/>
                                <field name="invoice_date"   readonly="1"/>
                            </group>
                            <group>
                                <field name="subtotal_before_tax" readonly="1"/>
                                <field name="tax_amount"          readonly="1"/>
                                <field name="total_amount"        readonly="1"/>
                                <field name="unmatched_count" readonly="1" string="Líneas sin producto"/>
                                <div invisible="unmatched_count == 0"
                                     style="color:#dc3545;font-size:0.85em">
                                    ⚠️ Líneas sin producto usarán KES-MISC (genérico).
                                </div>
                            </group>
                        </group>

                        <group string="📊 Cuenta Analítica (Opcional)" colspan="4">
                            <field name="analytic_account_id"
                                   string="Cuenta Analítica"
                                   options="{'no_quick_create': false}"
                                   placeholder="Dejar vacío si no aplica..."/>
                            <div invisible="not analytic_account_id"
                                 style="color:#155724;font-size:0.85em;margin-top:4px">
                                ✅ Se aplicará al 100% en todas las líneas de la orden.
                            </div>
                        </group>

                        <group string="✅ Checklist de Aprobación" colspan="4">
                            <field name="approve_vendor_ok"  string="Proveedor correcto y NIT verificado"/>
                            <field name="approve_lines_ok"   string="Líneas, productos y cantidades verificadas"/>
                            <field name="approve_amounts_ok" string="Montos, IVA y total verificados"/>
                            <field name="approve_notes"
                                   string="Notas (opcional)"
                                   placeholder="Autorizado por... / Observaciones..."/>
                        </group>

                    </group>

                    <!-- ══════════════════════════════════════════════
                         STAGE 4 — DONE
                         ══════════════════════════════════════════════ -->
                    <group invisible="state != 'done'">
                        <div colspan="4" style="padding:16px;background:#d4edda;border-radius:6px;border:1px solid #c3e6cb">
                            <h4 style="color:#155724">✅ Borrador de Orden de Compra Creado</h4>
                            <p style="color:#155724;margin:0">
                                La orden fue creada en estado <b>Borrador</b>.
                                Ábrela, revísala y confírmala cuando estés listo.
                            </p>
                        </div>
                        <field name="purchase_order_id" readonly="1" colspan="4"/>
                    </group>

                </sheet>

                <footer>
                    <!-- Stage 1 -->
                    <button name="action_analyze_with_ai"
                            type="object"
                            string="🔍 Analizar con IA"
                            class="btn-primary"
                            invisible="state != 'upload'"/>

                    <!-- Stage 2 -->
                    <button name="action_analyze_with_ai"
                            type="object"
                            string="🔄 Re-Analizar"
                            class="btn-secondary"
                            invisible="state != 'review'"/>
                    <button name="action_proceed_to_approve"
                            type="object"
                            string="➡️ Proceder a Aprobar"
                            class="btn-primary"
                            invisible="state != 'review'"/>

                    <!-- Stage 3 -->
                    <button name="action_go_back_to_review"
                            type="object"
                            string="← Volver a Revisar"
                            class="btn-secondary"
                            invisible="state != 'approve'"/>
                    <button name="action_approve_and_create_po"
                            type="object"
                            string="✅ Aprobar y Crear Orden de Compra"
                            class="btn-success"
                            invisible="state != 'approve'"/>

                    <!-- Stage 4 -->
                    <button name="action_open_po"
                            type="object"
                            string="📋 Ver Orden de Compra"
                            class="btn-primary"
                            invisible="state != 'done'"/>

                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>